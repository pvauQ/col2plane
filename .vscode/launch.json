{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with args",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/col2plane",  // from CMake
            "args": ["--cctag_from_file", "tags.txt"],  // ← RUNTIME ARGS HERE
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/bin/gdb",
            "environment": [

                {
                    "name": "DEBUGINFOD_CACHE_PATH",
                    "value": "${env:HOME}/.cache/debuginfod_client"
                }
            ]
        }
    ]
}
